# ── 애플리케이션 ──────────────────────────────
APP_NAME=경비처리 API
ENVIRONMENT=dev              # dev | prod

# ── 데이터베이스 ──────────────────────────────
# 개발(빠른 실행): sqlite. 운영: PostgreSQL(RDS)
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql+psycopg://expense:expense@localhost:5432/expense

# ── JWT 인증 ─────────────────────────────────
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ── 파일 저장 (MVP: 로컬 / 운영: S3) ─────────────
UPLOAD_DIR=storage/uploads
EXPORT_DIR=storage/exports

# ── CLOVA OCR (선택) ─────────────────────────────
# 두 값이 모두 있으면 실연동, 없으면 스텁(수동 입력). IAM 키가 아니라 OCR 도메인의 값 사용.
# ★ 실제 값은 여기(.env.example)가 아니라 .env 에 넣으세요 (.env 는 git 제외됨).
# CLOVA_OCR_INVOKE_URL=https://xxxxx.apigw.ntruss.com/custom/v1/00000/xxxx/general
# CLOVA_OCR_SECRET=<OCR 도메인 Secret Key (X-OCR-SECRET)>
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=
